# Kuli 3.0 local defaults
# 用法：复制为 `.env`，本地从仓库根目录运行 `npm run start:local` 时会读取这里面的变量。
# 注意：真实密钥只写到 `.env` 或部署平台 Secret Manager，不要提交到 git。

# 当前运行环境。
# local：本地开发，允许 SQLite/local storage/local-rules 等降级。
# staging/production：发布环境，会把 Redis、对象存储、邮件等依赖视为更严格的必需项。
APP_ENV=local

# 后端签名密钥，用于登录 token、邮箱验证 token、密码重置 token 等签名。
# 本地可以先用默认值；正式环境必须换成强随机值。
# 生成方式：openssl rand -hex 32
APP_SECRET_KEY=replace-with-long-secret

# 数据库连接字符串。
# 本地推荐使用一键脚本创建的 Postgres 数据库：kuli_runtime。
# 格式：postgresql+psycopg://用户名:密码@主机:端口/数据库名
# 如果只做最轻量本地调试，也可以临时改成：sqlite:///./apps/api/data/kuli-v2.sqlite
# 正式环境必须使用 Postgres + pgvector。
DATABASE_URL=postgresql+psycopg://kuli:kuli@localhost:5432/kuli_runtime

# Redis 连接字符串，用于 Celery worker、后台任务、通知任务等。
# 本地由 docker-compose 暴露在 6379。
# 云 Redis 常见格式：redis://:密码@主机:6379/0
REDIS_URL=redis://localhost:6379/0

# 允许访问 API 的前端来源，多个地址用英文逗号分隔。
# 本地保留 localhost/127.0.0.1；正式环境加入你的官网域名。
# 示例：https://www.kuli.example,https://kuli.example
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 登录 token 有效期，单位分钟。
# 1440 = 1 天。想让登录保持更久可以调大；安全要求更高时调小。
ACCESS_TOKEN_EXPIRE_MINUTES=1440000

# 前端访问后端 API 的基础地址。
# 本地固定为 FastAPI 地址；正式环境填 API 域名。
NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 站点公开访问地址，用于 canonical、Open Graph、sitemap、robots 等 SEO 输出。
# 本地填前端地址；正式环境填官网地址。
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# 前端应用名，会用于页面展示和部分 metadata。
NUXT_PUBLIC_APP_NAME=Kuli

# 是否启用右下角小酷 3D Agent。
# true：显示；false：隐藏。
NUXT_PUBLIC_ENABLE_XIAOKU=true

# 附件对象存储 provider。
# local：本地开发，文件写入 apps/api/data/uploads。
# s3：AWS S3 或兼容 S3 的服务。
# r2：Cloudflare R2，走 S3-compatible 接口。
# oss：阿里云 OSS。
OBJECT_STORAGE_PROVIDER=local

# 对象存储 endpoint。
# local 时留空。
# S3 可留空或填自定义 endpoint；R2 填 Cloudflare R2 endpoint；OSS 示例：https://oss-cn-hangzhou.aliyuncs.com
OBJECT_STORAGE_ENDPOINT=

# 对象存储 bucket 名称。
# local 时只是逻辑 bucket 名；正式环境需要先在 S3/R2/OSS 控制台创建私有 bucket。
OBJECT_STORAGE_BUCKET=kuli-order-files

# 对象存储区域。
# local 可用 auto；AWS/OSS 按控制台区域填写，例如 us-east-1、cn-hangzhou。
OBJECT_STORAGE_REGION=auto

# 本地附件保存目录。
# 只有 OBJECT_STORAGE_PROVIDER=local 时使用，客户上传的图片/附件会落到这个目录。
# 本地开发保持默认即可；正式环境如果使用 s3/r2/oss，本项不会作为最终附件存储位置。
OBJECT_STORAGE_LOCAL_DIR=apps/api/data/uploads

# 对象存储 Access Key ID。
# local 留空。
# 正式环境从云厂商 IAM/RAM 创建最小权限密钥，只给目标 bucket 的上传/下载/读取 metadata 权限。
OBJECT_STORAGE_ACCESS_KEY_ID=

# 对象存储 Secret Access Key。
# local 留空。
# 正式环境从云厂商 IAM/RAM 获取，必须保密。
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# 对象存储公开基础 URL。
# 如果 bucket 全私有且全部通过短期签名下载，可以留空。
# 如果前面接了 CDN，可填 CDN 域名，例如：https://files.kuli.example
OBJECT_STORAGE_PUBLIC_BASE_URL=

# 上传/下载预签名 URL 有效期，单位秒。
# 3600 = 1 小时。本地无所谓；正式环境建议 900-3600 之间。
OBJECT_STORAGE_PRESIGN_EXPIRES_SECONDS=3600

# 通用 LLM provider。
# local-rules：不调用远程模型，只用本地规则 fallback。
# openai-compatible：调用 OpenAI 或兼容 OpenAI Chat Completions 的服务。
LLM_PROVIDER=local-rules

# 通用 LLM 模型名。
# local-rules 时保持 local-rules。
# 启用远程模型时填服务商支持的真实模型名，例如 gpt-4.1、gpt-5.5 或其他兼容模型。
LLM_MODEL=local-rules

# 通用 LLM API Key。
# local-rules 留空。
# 远程模型从 OpenAI 或兼容服务商控制台获取。
LLM_API_KEY=

# 通用 LLM API base URL。
# OpenAI 官方默认：https://api.openai.com/v1
# 第三方兼容服务填对应 base URL。
LLM_BASE_URL=https://api.openai.com/v1

# OpenAI-compatible API Key，小酷和 embedding 可以直接读取这个值。
# 不填时，小酷仍可用本地规则 fallback；填了才会调用远程模型/embedding。
OPENAI_API_KEY=

# 小酷远程回答模型名。
# 注意必须填你的服务商真实支持的模型；如果服务商没有 gpt-5.5，就换成可用模型。
OPENAI_MODEL=gpt-5.5

# OpenAI-compatible base URL。
# OpenAI 官方默认：https://api.openai.com/v1
# 如果使用中转或其他兼容平台，填对方提供的地址。
OPENAI_BASE_URL=https://token.gepinkeji.com/v1

# LLM 请求超时时间，单位秒。
LLM_TIMEOUT_SECONDS=20

# 知识库 embedding 模型。
# OpenAI 常用：text-embedding-3-small。
# 如果使用其他 embedding 模型，要同步修改 VECTOR_DIMENSION。
EMBEDDING_MODEL=text-embedding-3-small

# embedding 向量维度。
# text-embedding-3-small 默认 1536。
# 必须和实际 embedding 模型输出维度一致，否则 pgvector 检索会出问题。
VECTOR_DIMENSION=1536

# 小酷/文档中心的 Markdown 知识库目录。
# 通常不需要改；要改时确保目录里有 quick-start、concepts、faq、guides、contact 五个 md。
KNOWLEDGE_ROOT=apps/api/knowledge/docs

# 是否启用小酷 Agent 后端能力。
XIAOKU_AGENT_ENABLED=true

# 小酷回答是否要求引用知识库来源。
# true：回答尽量带 citations；false：允许不带引用。
XIAOKU_REQUIRE_CITATIONS=true

# 邮件 provider。
# 本地留空：邮件事件会失败但站内通知仍可见，适合开发。
# 正式环境建议 smtp 或后续接入的邮件 API provider。
MAIL_PROVIDER=

# 发件人地址。
# 本地留空。
# 正式环境填已在邮件服务商验证过的发件地址，例如：no-reply@your-domain.com
MAIL_FROM=

# 回复地址。
# 用户点击邮件回复时会发到这里，例如：support@your-domain.com
MAIL_REPLY_TO=

# SMTP 主机。
# 只有 MAIL_PROVIDER=smtp 时需要。
# 例：smtpdm.aliyun.com、smtp.gmail.com、smtp.sendgrid.net。
SMTP_HOST=

# SMTP 端口。
# 常见：587 STARTTLS，465 SSL。
SMTP_PORT=587

# SMTP 用户名。
# 从邮件服务商后台获取，有时是完整邮箱，有时是 access key。
SMTP_USERNAME=

# SMTP 密码或 token。
# 从邮件服务商后台获取，必须保密。
SMTP_PASSWORD=

# 邮箱验证链接有效期，单位分钟。
EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=60

# 密码重置链接有效期，单位分钟。
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# 通知发送失败最大重试次数。
NOTIFICATION_MAX_RETRIES=3

# =========================
# 本地一键启动脚本可选覆盖项
# =========================
# 以下变量主要给 `npm run start:local` / `npm run stop:local` / smoke 测试使用。
# 不填也能启动，只有端口冲突、想换数据库名、想换 tmux session 名时才需要设置。

# Docker Compose 项目名，会影响容器名前缀。
# 默认：kuli-order-system。
COMPOSE_PROJECT_NAME=kuli-order-system

# 一键启动脚本创建/连接的本地 Postgres 数据库名。
# 默认：kuli_runtime。想隔离一套本地数据时可以改成 kuli_runtime_dev2。
KULI_LOCAL_DB_NAME=kuli_runtime

# 一键启动脚本使用的数据库连接。
# 不填时脚本会根据 KULI_LOCAL_DB_NAME 自动生成。
# 如果你已经有自己的本地 Postgres，可以取消注释并改成你的连接。
# KULI_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/DB_NAME

# API 监听地址和端口。
# API_HOST=0.0.0.0 表示允许本机所有网卡访问；只想本机访问可改成 127.0.0.1。
API_HOST=0.0.0.0
API_PORT=8000

# Web 监听地址和端口。
WEB_HOST=0.0.0.0
WEB_PORT=3000

# tmux session 名称。端口相同但想并行开多套服务时可改。
KULI_API_SESSION=kuli-api
KULI_WEB_SESSION=kuli-web
KULI_WORKER_SESSION=kuli-worker

# 浏览器 smoke 测试地址。
# 运行 `npm run smoke:browser` 时可覆盖这些值。
BASE_URL=http://127.0.0.1:3000
API_BASE_URL=http://127.0.0.1:8000
SMOKE_TIMEOUT_MS=90000

# Playwright 浏览器选择。
# 本机 Chrome 可用时默认 channel=chrome；如果要指定可执行文件，填绝对路径。
PLAYWRIGHT_CHANNEL=chrome
# PLAYWRIGHT_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# 生产栈验证脚本保护项。
# `npm run verify:production-stack` 默认拒绝直接操作非本地数据库。
# 只有你确认要验证远程生产/预发库时才设置为 true。
ALLOW_NONLOCAL_PRODUCTION_VERIFY=false

# 生产栈验证等待 Postgres 就绪的超时时间，单位秒。
VERIFY_TIMEOUT_SECONDS=30
