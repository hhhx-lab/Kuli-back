# Kuli backend
# 本地开发默认端口。前端 VITE_API_BASE_URL 要指向这个地址。
PORT=4000

# 允许访问 API 的前端地址。Vite 默认是 5173；如果端口被占用改成 5174/5175，要同步修改这里。
CORS_ORIGIN=http://localhost:5173

# JWT 签名密钥：生产环境必须换成 32 字符以上随机字符串。
JWT_SECRET=replace-with-a-long-random-secret

# 当前代码使用 SQLite 作为本地/测试 fallback。
DATABASE_PATH=data/kuli.sqlite

# 当前附件上传写入本地对象存储 fallback；数据库只保存 storageKey/metadata。
LOCAL_OBJECT_STORE_DIR=data/object-store

# 生产预留：正式接 Postgres / S3/R2/OSS 时再启用对应 adapter。
# DATABASE_URL=postgresql://kuli:password@localhost:5432/kuli_orders
# OBJECT_STORAGE_PROVIDER=s3
# OBJECT_STORAGE_ENDPOINT=https://s3.example.com
# OBJECT_STORAGE_BUCKET=kuli-order-files
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_ACCESS_KEY_ID=replace-me
# OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-me
