# Kuli 3.0 Web local defaults
# 用法：如果你单独进入 apps/web 启动 Nuxt，可以复制本文件为 apps/web/.env。
# 如果从仓库根目录运行 `npm run start:local`，主要读取根目录 `.env`。
# NUXT_PUBLIC_* 变量会进入前端 bundle，不要放任何密钥。

# 前端访问 FastAPI 的基础地址。
# 本地填 http://127.0.0.1:8000。
# 正式环境填 API 域名，例如：https://api.your-domain.com
NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# 官网公开访问地址，用于 canonical、Open Graph、sitemap、robots。
# 本地填 http://127.0.0.1:3000。
# 正式环境填官网域名，例如：https://www.your-domain.com
NUXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# 前端应用名，用于页面展示和 metadata。
NUXT_PUBLIC_APP_NAME=Kuli

# 是否显示右下角小酷 3D Agent。
# true：显示；false：隐藏。
NUXT_PUBLIC_ENABLE_XIAOKU=true
