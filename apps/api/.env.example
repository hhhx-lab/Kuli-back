# Kuli 3.0 API local defaults
# 用法：如果你单独进入 apps/api 启动后端，可以复制本文件为 apps/api/.env。
# 如果从仓库根目录运行 `npm run start:local`，主要读取根目录 `.env`。
# 真实密钥只写到 `.env` 或部署平台 Secret Manager，不要提交到 git。

# 当前运行环境：local / staging / production。
APP_ENV=local

# 后端签名密钥，用于登录 token、邮箱验证 token、密码重置 token。
# 正式环境生成方式：openssl rand -hex 32
APP_SECRET_KEY=replace-with-long-secret

# 数据库连接。正式环境必须使用 Postgres + pgvector。
# 本地一键脚本使用 kuli_runtime，避免污染旧 demo 数据库。
DATABASE_URL=postgresql+psycopg://kuli:kuli@localhost:5432/kuli_runtime

# Redis 连接，用于 Celery worker、后台任务和通知任务。
REDIS_URL=redis://localhost:6379/0

# 允许访问 API 的前端来源，多个用英文逗号分隔。
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# 登录 token 有效期，单位分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 附件对象存储 provider：local / s3 / r2 / oss。
OBJECT_STORAGE_PROVIDER=local

# 对象存储 endpoint。local 留空；OSS 示例：https://oss-cn-hangzhou.aliyuncs.com。
OBJECT_STORAGE_ENDPOINT=

# 对象存储 bucket 名称。
OBJECT_STORAGE_BUCKET=kuli-order-files

# 对象存储区域。local 可用 auto。
OBJECT_STORAGE_REGION=auto

# 本地附件保存目录。只有 OBJECT_STORAGE_PROVIDER=local 时使用。
OBJECT_STORAGE_LOCAL_DIR=apps/api/data/uploads

# 对象存储 Access Key ID。local 留空；正式环境从云厂商 IAM/RAM 获取。
OBJECT_STORAGE_ACCESS_KEY_ID=

# 对象存储 Secret Access Key。local 留空；正式环境必须保密。
OBJECT_STORAGE_SECRET_ACCESS_KEY=

# CDN 或 bucket 公开基础 URL。私有签名下载可留空。
OBJECT_STORAGE_PUBLIC_BASE_URL=

# 上传/下载预签名 URL 有效期，单位秒。
OBJECT_STORAGE_PRESIGN_EXPIRES_SECONDS=3600

# LLM provider。local-rules 不调用远程模型；openai-compatible 调用兼容 OpenAI 的服务。
LLM_PROVIDER=local-rules

# 通用 LLM 模型名。local-rules 时保持 local-rules。
LLM_MODEL=local-rules

# 通用 LLM API Key。local-rules 留空。
LLM_API_KEY=

# 通用 LLM API base URL。
LLM_BASE_URL=https://api.openai.com/v1

# OpenAI-compatible API Key，小酷和 embedding 可读取。
OPENAI_API_KEY=

# 小酷远程回答模型名。必须填服务商真实支持的模型。
OPENAI_MODEL=gpt-5.5

# OpenAI-compatible base URL。
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 请求超时，单位秒。
LLM_TIMEOUT_SECONDS=20

# embedding 模型。更换模型时同步改 VECTOR_DIMENSION。
EMBEDDING_MODEL=text-embedding-3-small

# embedding 向量维度。text-embedding-3-small 默认 1536。
VECTOR_DIMENSION=1536

# Markdown 知识库目录。
KNOWLEDGE_ROOT=apps/api/knowledge/docs

# 是否启用小酷 Agent。
XIAOKU_AGENT_ENABLED=true

# 小酷回答是否要求 citations。
XIAOKU_REQUIRE_CITATIONS=true

# 邮件 provider。本地留空；正式环境建议 smtp。
MAIL_PROVIDER=

# 发件人地址，例如 no-reply@your-domain.com。
MAIL_FROM=

# 回复地址，例如 support@your-domain.com。
MAIL_REPLY_TO=

# SMTP 主机。MAIL_PROVIDER=smtp 时必填。
SMTP_HOST=

# SMTP 端口。常见 587 或 465。
SMTP_PORT=587

# SMTP 用户名。
SMTP_USERNAME=

# SMTP 密码或 token。
SMTP_PASSWORD=

# 邮箱验证链接有效期，单位分钟。
EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=60

# 密码重置链接有效期，单位分钟。
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# 通知发送失败最大重试次数。
NOTIFICATION_MAX_RETRIES=3
