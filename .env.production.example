# Kuli 3.0 production template
# 用法：复制到生产服务器 `.env`，或逐项写入部署平台 Secret Manager。
# 注意：本文件只能放占位说明，不要提交真实密钥。

# 生产环境固定使用 production。
APP_ENV=production

# 生产签名密钥。必须替换，不能使用示例值。
# 生成方式：openssl rand -hex 32
APP_SECRET_KEY=replace-with-strong-random-secret

# 生产 Postgres + pgvector 数据库连接。
# 从云数据库控制台获取 host、port、user、password、db name。
# 格式：postgresql+psycopg://USER:PASSWORD@HOST:5432/kuli
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/kuli

# 生产 Redis 连接，用于 Celery worker 和后台任务。
# 从云 Redis 控制台获取。
REDIS_URL=redis://:PASSWORD@HOST:6379/0

# 允许访问 API 的正式前端域名，多个用英文逗号分隔。
CORS_ORIGINS=https://www.example.com,https://example.com

# 登录 token 有效期，单位分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 正式 API 域名，前端会用它请求后端。
NUXT_PUBLIC_API_BASE_URL=https://api.example.com

# 正式官网域名，用于 SEO 和分享。
NUXT_PUBLIC_SITE_URL=https://www.example.com

# 应用名称。
NUXT_PUBLIC_APP_NAME=Kuli

# 是否显示小酷。
NUXT_PUBLIC_ENABLE_XIAOKU=true

# 生产环境建议使用 s3 / r2 / oss，不建议 local。
OBJECT_STORAGE_PROVIDER=oss

# 对象存储 endpoint。
# 阿里云 OSS 示例：https://oss-cn-hangzhou.aliyuncs.com
# Cloudflare R2 示例：https://<account-id>.r2.cloudflarestorage.com
OBJECT_STORAGE_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com

# 生产附件 bucket。建议私有 ACL，不要公开列目录。
OBJECT_STORAGE_BUCKET=kuli-order-files-prod

# bucket 所在区域。
OBJECT_STORAGE_REGION=cn-hangzhou

# 本地附件保存目录。生产环境使用 s3/r2/oss 时不会作为最终附件存储位置。
# 仅当临时设置 OBJECT_STORAGE_PROVIDER=local 做故障演练或单机测试时使用。
OBJECT_STORAGE_LOCAL_DIR=apps/api/data/uploads

# 对象存储 Access Key ID。用最小权限 key。
OBJECT_STORAGE_ACCESS_KEY_ID=replace-with-storage-access-key

# 对象存储 Secret Access Key。必须保密。
OBJECT_STORAGE_SECRET_ACCESS_KEY=replace-with-storage-secret-key

# CDN 或公开文件域名。若全部走短期签名下载，可以留空。
OBJECT_STORAGE_PUBLIC_BASE_URL=

# 预签名 URL 有效期，单位秒。生产建议 900-1800。
OBJECT_STORAGE_PRESIGN_EXPIRES_SECONDS=1800

# 生产 LLM provider。
# openai-compatible 表示调用 OpenAI 或兼容 OpenAI Chat Completions 的服务。
LLM_PROVIDER=openai-compatible

# 生产 LLM 模型名。必须填服务商真实支持的模型。
LLM_MODEL=gpt-5.5

# 生产 LLM API Key。
LLM_API_KEY=replace-with-llm-api-key

# LLM API base URL。
LLM_BASE_URL=https://api.openai.com/v1

# OpenAI-compatible API Key，可与 LLM_API_KEY 相同。
OPENAI_API_KEY=replace-with-openai-or-compatible-key

# 小酷远程回答模型名。必须填真实可用模型。
OPENAI_MODEL=gpt-5.5

# OpenAI-compatible base URL。
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM 请求超时，单位秒。
LLM_TIMEOUT_SECONDS=20

# embedding 模型。需要和 VECTOR_DIMENSION 匹配。
EMBEDDING_MODEL=text-embedding-3-small

# text-embedding-3-small 默认 1536；换模型时查服务商文档。
VECTOR_DIMENSION=1536

# 生产环境中，代码仓库内的 Markdown 知识库目录。
KNOWLEDGE_ROOT=apps/api/knowledge/docs

# 是否启用小酷 Agent。
XIAOKU_AGENT_ENABLED=true

# 是否要求小酷带 citations。
XIAOKU_REQUIRE_CITATIONS=true

# 邮件 provider。当前模板使用 smtp。
MAIL_PROVIDER=smtp

# 发件人地址。需要先在邮件服务商验证域名/邮箱。
MAIL_FROM=no-reply@example.com

# 回复地址。
MAIL_REPLY_TO=support@example.com

# SMTP 主机，从邮件服务商后台获取。
SMTP_HOST=smtp.example.com

# SMTP 端口，常见 587 或 465。
SMTP_PORT=587

# SMTP 用户名。
SMTP_USERNAME=replace-with-smtp-username

# SMTP 密码或 token。
SMTP_PASSWORD=replace-with-smtp-password

# 邮箱验证链接有效期，单位分钟。
EMAIL_VERIFY_TOKEN_EXPIRE_MINUTES=60

# 密码重置链接有效期，单位分钟。
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# 通知发送失败最大重试次数。
NOTIFICATION_MAX_RETRIES=3

# =========================
# 生产验证脚本可选项
# =========================
# 以下变量只给 `npm run verify:production-stack` 使用，不属于线上服务长期运行必需项。

# 默认 false，防止误把 migration/验证脚本跑到远程数据库。
# 只有你确认当前 DATABASE_URL 指向预发/生产且允许验证脚本执行时才改 true。
ALLOW_NONLOCAL_PRODUCTION_VERIFY=false

# 等待 Postgres 就绪的超时时间，单位秒。
VERIFY_TIMEOUT_SECONDS=30
